# ─── Application ───────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/millionblogs?schema=public

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Email ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@millionblogs.com

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Feature Flags ────────────────────────────────────
FEATURE_NEW_SEARCH=false
FEATURE_AI_SUGGESTIONS=false

# ─── Storage ──────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# ─── Monitoring ───────────────────────────────────────
SENTRY_DSN=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=millionblogs
