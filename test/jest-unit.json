{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../src",
  "testEnvironment": "node",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["**/*.(t|j)s"],
  "coverageDirectory": "../coverage",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/$1",
    "^@config/(.*)$": "<rootDir>/config/$1",
    "^@prisma/(.*)$": "<rootDir>/prisma/$1",
    "^@common/(.*)$": "<rootDir>/common/$1",
    "^@feature-flags/(.*)$": "<rootDir>/feature-flags/$1",
    "^@audit/(.*)$": "<rootDir>/audit/$1",
    "^@activity/(.*)$": "<rootDir>/activity/$1",
    "^@events/(.*)$": "<rootDir>/events/$1",
    "^@jobs/(.*)$": "<rootDir>/jobs/$1",
    "^@backup/(.*)$": "<rootDir>/backup/$1",
    "^@observability/(.*)$": "<rootDir>/observability/$1"
  }
}
